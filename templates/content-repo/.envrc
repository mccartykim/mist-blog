use flake

# Identity that the preview server displays in <title> and the site header.
# Uncomment and edit; preview will pick these up via parent-shell inheritance.
# These DO NOT affect production — production identity comes from the
# `services.mist-blog` options in your deployment flake.
#
# export BLOG_TITLE="My Blog"
# export BLOG_AUTHOR="Your Name"
# export BLOG_DESCRIPTION="A blog about ..."
# export BLOG_COPYRIGHT="Your Name (CC BY 4.0)"
# export BLOG_BASE_URL="https://example.com"
